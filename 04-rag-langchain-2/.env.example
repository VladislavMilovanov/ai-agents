TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/free
EMBEDDING_MODEL=openai/text-embedding-3-small

# Ассистент по продуктам Сбера (можно заменить своей формулировкой)
SYSTEM_PROMPT=Ты — ассистент по продуктам и услугам Сбербанка (кредиты, вклады, справка). Отвечай на русском, опирайся на контекст из документов. Не выдумывай тарифы и условия. Если в контексте нет ответа — скажи об этом.

RETRIEVER_K=4
DATA_DIR=data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

HISTORY_MAX_PAIRS=10
LLM_TIMEOUT_SEC=60
LOG_LEVEL=INFO

