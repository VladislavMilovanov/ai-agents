# Скопируй в .env и заполни. См. README и docs/vision.md (раздел про конфиг).

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- OpenRouter (обязательны для LLM, эмбеддингов и RAG) ---
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модель чата и модель эмбеддингов (имена с OpenRouter)
LLM_MODEL=openrouter/free
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- RAG ---
# Сколько чанков отдаёт retriever (целое >= 1)
RETRIEVER_K=4
# Папка с корпусом относительно корня проекта
DATA_DIR=data
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Диалог ---
DIALOG_HISTORY_LIMIT=10

# --- Поведение ---
# SYSTEM_PROMPT=  # опционально; иначе — дефолтный промпт из config.py
LOG_LEVEL=INFO
